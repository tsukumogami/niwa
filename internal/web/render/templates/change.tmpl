<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>niwa change {{.ID}}</title>
<style>{{.CSS}}</style>
</head>
<body>
<nav class="breadcrumbs"><a href="/workspaces/">workspaces</a> &rsaquo; <a href="/workspaces/{{.Workspace}}/"><code>{{.Workspace}}</code></a> &rsaquo; <a href="/workspaces/{{.Workspace}}/{{.Instance}}/changes/"><code>{{.Instance}}</code></a> &rsaquo; <code>{{.ID}}</code></nav>
<h1>Change <code>{{.ID}}</code><span class="badge {{.State}}">{{.State}}</span></h1>
<section class="meta">
<dl>
<dt>Workspace</dt><dd><code>{{.Workspace}}</code></dd>
<dt>Instance</dt><dd><code>{{.Instance}}</code></dd>
<dt>Originating session</dt><dd>{{if .OriginatingSession}}<code>{{.OriginatingSession}}</code>{{else}}<span class="empty">none</span>{{end}}</dd>
<dt>Base &rarr; head</dt><dd><code>{{.BaseRef}}</code> &rarr; <code>{{.HeadRef}}</code></dd>
<dt>Branch</dt><dd><code>{{.Branch}}</code></dd>
<dt>Created</dt><dd>{{.CreatedAt}}</dd>
<dt>Updated</dt><dd>{{.UpdatedAt}}</dd>
</dl>
</section>
<h2>Diff</h2>
{{if .Diff}}<pre class="diff">{{.Diff}}</pre>{{else}}<p class="empty">No changes.</p>{{end}}
</body>
</html>
