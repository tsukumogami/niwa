<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>niwa changes — {{.Workspace}}/{{.Instance}}</title>
<style>{{.CSS}}</style>
</head>
<body>
<nav class="breadcrumbs"><a href="/workspaces/">workspaces</a> &rsaquo; <a href="/workspaces/{{.Workspace}}/"><code>{{.Workspace}}</code></a> &rsaquo; <code>{{.Instance}}</code></nav>
<h1>Changes in <code>{{.Workspace}}/{{.Instance}}</code></h1>
{{if .Changes}}
<ul class="changes">
{{range .Changes}}<li{{if eq .State "cleaned"}} class="cleaned"{{end}}><a href="/workspaces/{{$.Workspace}}/{{$.Instance}}/changes/{{.ID}}"><code>{{.ID}}</code></a><span class="badge {{.State}}">{{.State}}</span> &mdash; updated {{.UpdatedAt}}</li>
{{end}}</ul>
{{else}}
<p class="empty">No changes in review yet. Changes appear here when an agent in this instance calls <code>niwa_create_change</code>.</p>
{{end}}
</body>
</html>
