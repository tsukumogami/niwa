<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>niwa surface — {{.Workspace}}</title>
<style>{{.CSS}}</style>
</head>
<body>
<nav class="breadcrumbs"><a href="/workspaces/">workspaces</a> &rsaquo; <code>{{.Workspace}}</code></nav>
<h1>Workspace <code>{{.Workspace}}</code></h1>
{{if .Instances}}
<ul class="instances">
{{range .Instances}}
<li><a href="/workspaces/{{.Workspace}}/{{.Instance}}/changes/"><code>{{.Instance}}</code></a> <span class="path">{{.Root}}</span></li>
{{end}}
</ul>
{{else}}
<p class="empty">No instances discovered under this workspace.</p>
{{end}}
</body>
</html>
